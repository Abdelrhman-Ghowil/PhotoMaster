# Copy this file to .env before running Docker Compose.

# Host port mapped to Streamlit's container port 8501.
PHOTOMASTER_PORT=8501

# Google Drive service account JSON. Keep this file outside Git.
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google_credentials

# External model locations inside the container.
OBJECT_ERASER_MODEL_PATH=/app/assets/big-lama.pt
REALESRGAN_MODEL_PATH=/app/assets/models/RealESRGAN_x4plus.pth

# The app can download the object eraser model here if it is not mounted.
OBJECT_ERASER_MODEL_URL=https://huggingface.co/spaces/aryadytm/remove-photo-object/resolve/main/assets/big-lama.pt

# Cache/model tuning.
HF_HOME=/app/.cache/huggingface
TRANSFORMERS_CACHE=/app/.cache/huggingface
TORCH_HOME=/app/.cache/torch
OBJECT_ERASER_SIZE_LIMIT=1280
TORCH_NUM_THREADS=2
